# Docker Environment Configuration for Asset Management
# Update these values for your setup, especially passwords and secrets!

# Database (MySQL)
DB_NAME=asset_management
DB_USER=assetuser
DB_PASSWORD=assetpass123  # Change this!
DB_ROOT_PASSWORD=rootpass123  # Change this! Root password for MySQL

# Backend
JWT_SECRET=your-super-secret-jwt-key-change-in-production-now!  # Generate a strong secret
PORT=3001  # Backend port (internal)

# Frontend (if needed for dev)
VITE_API_URL=http://localhost:3001/api  # API base for frontend

# Usage:
# docker-compose -f docker-compose.prod.yml up -d --build
# Access: http://localhost (frontend + API proxy)
# Dev: docker-compose -f docker-compose.debug.yml up (uses host DB)
